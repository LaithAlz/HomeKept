# HomeKept backend environment variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection. Local dev defaults are in application.yml.
DB_URL=jdbc:postgresql://localhost:5432/homekept
DB_USERNAME=homekept
DB_PASSWORD=changeme

# ─── JWT signing ─────────────────────────────────────────────────────────────
# HMAC-SHA256 signing key for access tokens.
# REQUIRED in production: must be ≥32 bytes of high entropy and must NOT be the
# well-known dev sentinel. Generate with: openssl rand -hex 32
# The startup guard in JwtService rejects blank, short (<32 bytes), or sentinel keys
# when APP_DEV_MODE=false (the default). Anyone can forge ADMIN tokens with a public key.
# Rotation: issue new key, restart API (existing tokens expire naturally within 15 min).
JWT_SIGNING_KEY=replace-with-openssl-rand-hex-32

# ─── Encryption (reserved — not used until V3 property migration) ─────────────
# AES-GCM key for property access_notes column-level encryption.
# Format: base64-encoded 256-bit key (openssl rand -base64 32).
# Leave empty in dev until the property domain is built.
ACCESS_NOTES_ENC_KEY=

# ─── Application ─────────────────────────────────────────────────────────────
APP_TIMEZONE=America/Toronto

# REQUIRED in production. Forces the Secure flag on all auth cookies (belt-and-suspenders
# alongside server.forward-headers-strategy=framework which reads X-Forwarded-Proto).
# Leave false (or unset) for plain-HTTP localhost dev.
APP_SECURE_COOKIES=true

# Set true ONLY for local development. When false (the default), the app refuses to start
# if JWT_SIGNING_KEY is blank, shorter than 32 bytes, or equals the well-known dev sentinel.
# NEVER set APP_DEV_MODE=true in production.
APP_DEV_MODE=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production: set to https://homekept.ca
CORS_ALLOWED_ORIGIN_1=http://localhost:5173
CORS_ALLOWED_ORIGIN_2=http://localhost:4173

# ─── Admin seed ──────────────────────────────────────────────────────────────
# When both are set and no user with that email exists, an ADMIN/ACTIVE user is
# created at startup (idempotent — existing users are never overwritten).
# For local testing, set both to whatever credentials you want to log in with
# (your own email and a password). NEVER commit real values here — set them in
# your gitignored .env. Unset (or leave blank) once the account exists.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# ─── Future integrations (not yet active) ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SENDGRID_API_KEY=SG....
# POSTHOG_API_KEY=phc_...
# R2_BUCKET_NAME=homekept-photos
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
